# 微信云托管控制台 → 服务设置 → 环境变量（复制填入）
WX_CLOUD_RUN=1
WX_CLOUD_SERVICE=watermark-api
WX_CLOUD_ENV_ID=prod-xxxx

# 云开发 MySQL（绑定数据库后自动注入，也可手动填写）
MYSQL_ADDRESS=10.x.x.x:3306
MYSQL_USERNAME=
MYSQL_PASSWORD=
MYSQL_DATABASE=ai_watermark

# 微信小程序
WX_APPID=
WX_APPSECRET=

# DeepSeek（推荐用环境变量，勿提交仓库）
DEEPSEEK_API_KEY=sk-xxx

# 公网访问地址（用于生成上传文件 URL）
CONTAINER_PUBLIC_URL=https://xxx.ap-shanghai.app.tcloudbase.com

# 压测密钥（生产请修改）
STRESS_TEST_KEY=your_stress_secret

# 调试 0/1
APP_DEBUG=0
