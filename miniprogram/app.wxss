/* 全局样式 - 轻奢科技风 */
page {
  background: #F5F6FA;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;
  color: #333;
  font-size: 28rpx;
  line-height: 1.6;
}

/* 主题色变量 */
:root {
  --primary: #5B6CF8;
  --primary-end: #8B5CF6;
  --bg: #F5F6FA;
  --card: rgba(255,255,255,0.92);
  --text-secondary: #999;
  --shadow: 0 8rpx 32rpx rgba(91,108,248,0.12);
}

/* 渐变主色 */
.gradient-primary {
  background: linear-gradient(135deg, #5B6CF8 0%, #8B5CF6 100%);
}

.gradient-text {
  background: linear-gradient(135deg, #5B6CF8, #8B5CF6);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

/* 磨砂卡片 */
.glass-card {
  background: rgba(255, 255, 255, 0.92);
  backdrop-filter: blur(20px);
  border-radius: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(91, 108, 248, 0.1);
  border: 1rpx solid rgba(255, 255, 255, 0.8);
}

/* 主按钮 */
.btn-primary {
  background: linear-gradient(135deg, #5B6CF8 0%, #8B5CF6 100%);
  color: #fff;
  border-radius: 48rpx;
  padding: 24rpx 48rpx;
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
  box-shadow: 0 12rpx 32rpx rgba(91, 108, 248, 0.35);
  transition: transform 0.15s;
}

.btn-primary:active {
  transform: scale(0.96);
}

.btn-outline {
  background: transparent;
  color: #5B6CF8;
  border: 2rpx solid #5B6CF8;
  border-radius: 48rpx;
  padding: 22rpx 48rpx;
  font-size: 28rpx;
  text-align: center;
}

/* 页面容器 */
.page-container {
  padding: 24rpx 32rpx;
  padding-bottom: 160rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 标题 */
.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 24rpx;
}

.section-sub {
  font-size: 24rpx;
  color: #999;
  margin-top: -16rpx;
  margin-bottom: 24rpx;
}

/* 功能卡片网格 */
.feature-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
}

.feature-item {
  flex: 1;
  min-width: 280rpx;
  padding: 36rpx 28rpx;
  border-radius: 24rpx;
  background: rgba(255,255,255,0.92);
  box-shadow: 0 8rpx 32rpx rgba(91,108,248,0.1);
}

.feature-item:active {
  transform: scale(0.98);
}

.feature-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-bottom: 20rpx;
}

.feature-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.feature-desc {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
}

/* 加载动画 */
.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 4rpx solid #E8E8F0;
  border-top-color: #5B6CF8;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 20rpx;
  color: #999;
  font-size: 26rpx;
}

/* 弹窗遮罩 */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-content {
  width: 600rpx;
  background: #fff;
  border-radius: 32rpx;
  padding: 48rpx 40rpx;
  text-align: center;
  animation: modalIn 0.3s ease;
}

@keyframes modalIn {
  from { opacity: 0; transform: scale(0.9); }
  to { opacity: 1; transform: scale(1); }
}

.modal-title {
  font-size: 34rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
}

.modal-desc {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 40rpx;
  line-height: 1.6;
}

.modal-btns {
  display: flex;
  gap: 20rpx;
}

.modal-btns .btn {
  flex: 1;
  padding: 22rpx 0;
  border-radius: 40rpx;
  font-size: 28rpx;
}

.modal-btns .btn-cancel {
  background: #F0F2F5;
  color: #666;
}

.modal-btns .btn-confirm {
  background: linear-gradient(135deg, #5B6CF8, #8B5CF6);
  color: #fff;
}

/* 次数标签 */
.count-badge {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 20rpx;
  background: linear-gradient(135deg, rgba(91,108,248,0.1), rgba(139,92,246,0.1));
  border-radius: 20rpx;
  font-size: 22rpx;
  color: #5B6CF8;
}

/* 底部广告占位 */
.ad-banner-placeholder {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  z-index: 99;
}
