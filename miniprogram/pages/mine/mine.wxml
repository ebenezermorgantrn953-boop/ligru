<view class="page-container">
  <view class="user-card glass-card" bindtap="onLogin">
    <image class="avatar" src="{{userInfo.avatar || '/assets/default-avatar.png'}}" mode="aspectFill"></image>
    <view class="user-info">
      <text class="nickname">{{userInfo.nickname || '点击登录'}}</text>
      <view class="user-tags">
        <text class="vip-tag" wx:if="{{userInfo.is_vip}}">👑 会员</text>
        <text class="count-tag" wx:else>剩余 {{userInfo.remain_count || 0}} 次</text>
      </view>
    </view>
    <text class="arrow">›</text>
  </view>

  <view class="stats-row glass-card">
    <view class="stat-item">
      <text class="stat-num">{{userInfo.total_use || 0}}</text>
      <text class="stat-label">累计使用</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-num">{{userInfo.today_use || 0}}</text>
      <text class="stat-label">今日使用</text>
    </view>
  </view>

  <view class="menu-list glass-card">
    <view class="menu-item" bindtap="goMember">
      <text class="menu-icon">👑</text>
      <text class="menu-text">会员中心</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goHistory">
      <text class="menu-icon">📋</text>
      <text class="menu-text">处理记录</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goHelp">
      <text class="menu-icon">📖</text>
      <text class="menu-text">使用帮助</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goFeedback">
      <text class="menu-icon">💬</text>
      <text class="menu-text">问题反馈</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>
</view>
