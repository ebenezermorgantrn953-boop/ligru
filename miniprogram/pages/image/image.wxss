.upload-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx;
  margin-bottom: 32rpx;
}

.upload-area:active { opacity: 0.9; }

.upload-icon { font-size: 80rpx; margin-bottom: 24rpx; }

.upload-text { font-size: 32rpx; font-weight: 600; color: #333; }

.upload-hint { font-size: 24rpx; color: #999; margin-top: 12rpx; }

.preview-img {
  width: 100%;
  max-height: 600rpx;
  border-radius: 16rpx;
}

.preview-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 32rpx;
}

.preview-actions .btn-outline,
.preview-actions .btn-primary { flex: 1; }

.result-area { padding: 32rpx; margin-top: 32rpx; }

.result-btns { margin-top: 32rpx; }
