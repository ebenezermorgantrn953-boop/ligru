.hero-banner {
  border-radius: 28rpx;
  padding: 48rpx 40rpx;
  margin-bottom: 40rpx;
  position: relative;
  overflow: hidden;
}

.hero-content { position: relative; z-index: 2; }

.hero-title {
  display: block;
  font-size: 44rpx;
  font-weight: 800;
  color: #fff;
  letter-spacing: 2rpx;
}

.hero-sub {
  display: block;
  font-size: 26rpx;
  color: rgba(255,255,255,0.85);
  margin-top: 12rpx;
}

.hero-badge {
  display: inline-block;
  margin-top: 24rpx;
  padding: 8rpx 24rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 24rpx;
  font-size: 24rpx;
  color: #fff;
}

.hero-deco {
  position: absolute;
  right: -40rpx;
  top: -40rpx;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.1);
}

.quick-list { padding: 0 8rpx; }

.quick-item {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid #F0F2F5;
}

.quick-item:last-child { border-bottom: none; }

.quick-item:active { background: #F8F9FC; }

.quick-icon { font-size: 36rpx; margin-right: 20rpx; }

.quick-text { flex: 1; font-size: 28rpx; color: #333; }

.quick-arrow { color: #CCC; font-size: 32rpx; }
