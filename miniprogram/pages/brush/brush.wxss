.tip-card { padding: 24rpx 32rpx; margin-bottom: 24rpx; }
.tip-text { font-size: 26rpx; color: #666; }

.canvas-wrap {
  position: relative;
  width: 100%;
  height: 600rpx;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  margin-bottom: 32rpx;
}

.brush-bg { width: 100%; height: 100%; }

.brush-canvas {
  position: absolute;
  top: 0; left: 0;
  width: 100%;
  height: 100%;
}

.brush-tools {
  display: flex;
  gap: 20rpx;
}

.brush-tools .btn-outline,
.brush-tools .btn-primary { flex: 1; }

.preview-img { width: 100%; max-height: 500rpx; border-radius: 16rpx; }

.upload-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx;
}

.upload-icon { font-size: 72rpx; margin-bottom: 20rpx; }
.upload-text { font-size: 30rpx; color: #333; }
